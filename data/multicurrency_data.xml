<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron pour la mise à jour automatique des taux de change (BAM/BCE/FloatRates) -->
        <record id="ir_cron_update_currency_rates" model="ir.cron">
            <field name="name">Compta Maroc: Mise à jour auto des Taux de Change (BAM/BCE)</field>
            <field name="model_id" ref="base.model_res_company"/>
            <field name="state">code</field>
            <field name="code">model._cron_update_currency_rates()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/> <!-- Désactivé par défaut, activable si auto_currency_update = True -->
        </record>
    </data>
</odoo>