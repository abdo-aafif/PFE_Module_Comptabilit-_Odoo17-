<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         UTILISATEURS DE TEST — 3 PERSONAS DU CAHIER DES CHARGES
         ================================================================
         ⚠️  COMPTES DE TEST UNIQUEMENT — mot de passe connu : « test1234 ».
             À DÉSACTIVER ou SUPPRIMER avant toute mise en PRODUCTION
             (retirer cette ligne du manifest ou archiver les utilisateurs).

         Correspondance Persona ↔ Groupe de sécurité Odoo :

           • Persona 1 — « Le Comptable / Chef comptable »
                 → account.group_account_manager
                   (opérations quotidiennes + clôture mensuelle avec
                    verrouillage de période, qui exige le niveau Manager)

           • Persona 2 — « Le Directeur Financier (DAF) »
                 → account.group_account_readonly
                   (consultation SEULE : Bilan, CPC, Dashboard, trésorerie ;
                    aucune saisie possible — conforme au persona)

           • Persona 3 — « Admin / Intégrateur Odoo »
                 → base.group_system + account.group_account_manager
                   (installation, configuration du plan comptable,
                    gestion des utilisateurs et des droits)

         Remarque : ces groupes impliquent déjà base.group_user
         (utilisateur interne) ; on l'ajoute explicitement par lisibilité.
         La société est fixée sur base.main_company pour éviter que les
         règles d'enregistrement multi-sociétés ne masquent les données.
         ================================================================ -->

    <!-- ───────────────────────────────────────────────────────────────
         Persona 1 — LE COMPTABLE (Chef comptable)
         Groupe : Manager comptable (« Paramétrage facturation »)
         ─────────────────────────────────────────────────────────────── -->
    <record id="user_demo_comptable" model="res.users">
        <field name="name">Comptable (Démo — Persona 1)</field>
        <field name="login">comptable@test.ma</field>
        <field name="password">admin</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="company_ids" eval="[(6, 0, [ref('base.main_company')])]"/>
        <field name="groups_id" eval="[(6, 0, [
            ref('base.group_user'),
            ref('account.group_account_manager'),
        ])]"/>
    </record>

    <!-- ───────────────────────────────────────────────────────────────
         Persona 2 — LE DIRECTEUR FINANCIER (DAF)
         Groupe : Lecture seule comptable (consultation des états)
         ─────────────────────────────────────────────────────────────── -->
    <record id="user_demo_daf" model="res.users">
        <field name="name">DAF (Démo — Persona 2)</field>
        <field name="login">daf@test.ma</field>
        <field name="password">admin</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="company_ids" eval="[(6, 0, [ref('base.main_company')])]"/>
        <field name="groups_id" eval="[(6, 0, [
            ref('base.group_user'),
            ref('account.group_account_readonly'),
        ])]"/>
    </record>

    <!-- ───────────────────────────────────────────────────────────────
         Persona 3 — ADMIN / INTÉGRATEUR ODOO
         Groupe : Paramètres (base.group_system) + Manager comptable
         ─────────────────────────────────────────────────────────────── -->
    <record id="user_demo_admin" model="res.users">
        <field name="name">Admin Intégrateur (Démo — Persona 3)</field>
        <field name="login">admin@test.ma</field>
        <field name="password">admin</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="company_ids" eval="[(6, 0, [ref('base.main_company')])]"/>
        <field name="groups_id" eval="[(6, 0, [
            ref('base.group_user'),
            ref('base.group_system'),
            ref('account.group_account_manager'),
        ])]"/>
    </record>

</odoo>
