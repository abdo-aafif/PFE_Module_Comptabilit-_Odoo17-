<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ================================================================
             PUSH 1 — Sécurité minimale (Plan Comptable + Analytique)
             ================================================================
             Pas encore de record rules ici : aucun modèle custom dans le P1.
             Les record rules multi-société seront ajoutées au fur et à mesure
             des pushes suivants, en même temps que les modèles concernés.
             ================================================================ -->

        <!-- DÉBRIDAGE ODOO COMMUNITY :
             Forcer l'affichage des "Caractéristiques comptables complètes"
             (Débit/Crédit, Journaux, etc.) pour tous les utilisateurs qui
             ont accès à la facturation/comptabilité. -->

        <record id="account.group_account_invoice" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('account.group_account_user')), (4, ref('account.group_account_readonly'))]"/>
        </record>

        <record id="account.group_account_manager" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('account.group_account_user')), (4, ref('account.group_account_readonly'))]"/>
        </record>

        <!-- COMPTABILITÉ ANALYTIQUE :
             Activer automatiquement la fonctionnalité analytique pour tous
             les utilisateurs comptables. Sans cela, le champ
             analytic_distribution est invisible dans les écritures et les
             factures. -->
        <record id="account.group_account_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('analytic.group_analytic_accounting'))]"/>
        </record>
    </data>
</odoo>
