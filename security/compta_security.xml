<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ================================================================
             PUSH 1 — Sécurité minimale (Plan Comptable + Analytique)
             ================================================================
             Pas encore de record rules ici : aucun modèle custom dans le P1.
             Les record rules multi-société seront ajoutées au fur et à mesure
             des pushes suivants, en même temps que les modèles concernés.
             ================================================================ -->

        <!-- DÉBRIDAGE ODOO COMMUNITY :
             Forcer l'affichage des "Caractéristiques comptables complètes"
             (Débit/Crédit, Journaux, etc.) pour tous les utilisateurs qui
             ont accès à la facturation/comptabilité. -->

        <record id="account.group_account_invoice" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('account.group_account_user')), (4, ref('account.group_account_readonly'))]"/>
        </record>

        <record id="account.group_account_manager" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('account.group_account_user')), (4, ref('account.group_account_readonly'))]"/>
        </record>

        <!-- COMPTABILITÉ ANALYTIQUE :
             Activer automatiquement la fonctionnalité analytique pour tous
             les utilisateurs comptables. Sans cela, le champ
             analytic_distribution est invisible dans les écritures et les
             factures. -->
        <record id="account.group_account_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('analytic.group_analytic_accounting'))]"/>
        </record>

        <!-- ================================================================
             Section 3.1.5 du CDC : Déclarations Fiscales (TVA)
             Règles multi-sociétés pour isoler les déclarations par société.
             ================================================================ -->
        <record id="rule_account_tva_declaration_company" model="ir.rule">
            <field name="name">Déclaration TVA : accès par société</field>
            <field name="model_id" ref="model_account_tva_declaration"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_account_tva_declaration_line_company" model="ir.rule">
            <field name="name">Ligne ventilation TVA : accès par société</field>
            <field name="model_id" ref="model_account_tva_declaration_line"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_account_tva_declaration_detail_company" model="ir.rule">
            <field name="name">Détail audit TVA : accès par société</field>
            <field name="model_id" ref="model_account_tva_declaration_detail"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- ================================================================
             Section 3.1.6 du CDC : Reporting de Base (vues SQL)
             Règles multi-sociétés pour isoler les rapports par société.
             ================================================================ -->
        <record id="rule_compta_balance_generale_company" model="ir.rule">
            <field name="name">Balance Générale : accès par société</field>
            <field name="model_id" ref="model_compta_balance_generale"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_compta_grand_livre_company" model="ir.rule">
            <field name="name">Grand Livre : accès par société</field>
            <field name="model_id" ref="model_compta_grand_livre"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_compta_journal_centralisateur_company" model="ir.rule">
            <field name="name">Journal Centralisateur : accès par société</field>
            <field name="model_id" ref="model_compta_journal_centralisateur"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_compta_balance_agee_company" model="ir.rule">
            <field name="name">Balance Âgée : accès par société</field>
            <field name="model_id" ref="model_compta_balance_agee"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- ================================================================
             Section 3.2.2 du CDC : Gestion des Immobilisations
             Règles multi-sociétés pour isoler les immobilisations par société.
             ================================================================ -->
        <record id="rule_account_asset_company" model="ir.rule">
            <field name="name">Immobilisation : accès par société</field>
            <field name="model_id" ref="model_account_asset"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_account_asset_category_company" model="ir.rule">
            <field name="name">Catégorie immobilisation : accès par société</field>
            <field name="model_id" ref="model_account_asset_category"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
