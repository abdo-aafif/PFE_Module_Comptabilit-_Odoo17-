<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 2. Action explicite pour garantir à 100% que la création manuelle s'ouvre comme une Opération Diverse pure -->
    <record id="action_compta_saisie_manuelle" model="ir.actions.act_window">
        <field name="name">Saisies Manuelles (OD, A-Nouveaux)</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,kanban,form</field>
        <!-- US-019 : la liste affiche TOUTES les écritures (OD, factures clients/
             fournisseurs, banque, à-nouveaux), tous journaux confondus, pour
             consultation et filtrage par journal / période / état. La création
             reste une OD pure grâce à default_move_type='entry' (contexte). -->
        <field name="domain">[]</field>
        <field name="context">{'default_move_type': 'entry', 'view_no_maturity': True}</field>
        <field name="view_id" ref="account.view_move_tree"/>
    </record>

    <!-- 6. Vue tree partagée pour le Lettrage -->
    <record id="view_account_move_line_lettrage_tree" model="ir.ui.view">
        <field name="name">account.move.line.lettrage.tree</field>
        <field name="model">account.move.line</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <tree string="Lettrage des Comptes"
                  create="false" delete="false" edit="false"
                  decoration-warning="not reconciled and amount_residual != 0"
                  decoration-success="reconciled">
                <field name="date"/>
                <field name="move_id" string="Pièce"/>
                <field name="journal_id" string="Journal" optional="show"/>
                <field name="account_id" string="Compte"/>
                <field name="partner_id" string="Partenaire"/>
                <field name="name" string="Libellé" optional="show"/>
                <field name="debit" sum="Total Débit"/>
                <field name="credit" sum="Total Crédit"/>
                <field name="amount_residual" string="Solde restant" sum="Solde"/>
                <field name="full_reconcile_id" string="Lettrage #"/>
                <field name="reconciled" column_invisible="1"/>
                <field name="balance" column_invisible="1"/>
                <field name="company_id" column_invisible="1"/>
                <field name="company_currency_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- 6.bis Action : Écritures À Lettrer (non lettrées, groupées par partenaire) -->
    <record id="action_compta_lettrage_comptes" model="ir.actions.act_window">
        <field name="name">Écritures à Lettrer</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_account_move_line_lettrage_tree"/>
        <field name="domain">[
            ('account_id.reconcile', '=', True),
            ('parent_state', '=', 'posted'),
            ('display_type', 'not in', ['line_section', 'line_note']),
            ('reconciled', '=', False),
        ]</field>
        <field name="context">{'search_default_partner': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucune écriture en attente de lettrage.</p>
            <p>
                <b>Comment lettrer ?</b><br/>
                1. Dépliez un partenaire<br/>
                2. Cochez la facture (Débit) + son paiement (Crédit)<br/>
                3. Menu <b>Action → Lettrer les écritures sélectionnées</b>
            </p>
        </field>
    </record>

    <!-- 6.ter Action : Historique Lettrage (lettrées, groupées par numéro de lettrage) -->
    <record id="action_compta_lettrage_historique" model="ir.actions.act_window">
        <field name="name">Historique du Lettrage</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_account_move_line_lettrage_tree"/>
        <field name="domain">[
            ('account_id.reconcile', '=', True),
            ('parent_state', '=', 'posted'),
            ('display_type', 'not in', ['line_section', 'line_note']),
            ('reconciled', '=', True),
        ]</field>
        <field name="context">{'search_default_full_reconcile': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucun lettrage enregistré.</p>
        </field>
    </record>

    <!-- 6.ter Action serveur : Lettrer les lignes sélectionnées -->
    <record id="action_server_lettrer_lignes" model="ir.actions.server">
        <field name="name">Lettrer les écritures sélectionnées</field>
        <field name="model_id" ref="account.model_account_move_line"/>
        <field name="binding_model_id" ref="account.model_account_move_line"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    # Filtrer : uniquement lignes non lettrées sur comptes réconciliables
    to_reconcile = records.filtered(
        lambda l: not l.reconciled
        and l.account_id.reconcile
        and l.parent_state == 'posted'
    )
    if not to_reconcile:
        raise UserError("Aucune ligne lettrable dans la sélection (déjà lettrées ou compte non réconciliable).")

    # Vérifier qu'elles sont sur le même compte
    accounts = to_reconcile.account_id
    if len(accounts) != 1:
        raise UserError(
            "Toutes les lignes doivent être sur le MÊME compte pour être lettrées.\n"
            "Comptes trouvés : %s" % ", ".join(accounts.mapped('display_name'))
        )

    # Vérifier équilibre débit/crédit
    total = sum(to_reconcile.mapped('balance'))
    if abs(total) &gt; 0.01:
        raise UserError(
            "Le débit et le crédit ne s'équilibrent pas (écart : %.2f).\n"
            "Ajustez votre sélection ou créez une écriture d'écart." % total
        )

    to_reconcile.reconcile()
    action = {
        'type': 'ir.actions.client',
        'tag': 'display_notification',
        'params': {
            'title': 'Lettrage effectué',
            'message': '%d ligne(s) lettrée(s) sur le compte %s.' % (len(to_reconcile), accounts.display_name),
            'type': 'success',
            'next': {'type': 'ir.actions.act_window_close'},
        },
    }
        </field>
    </record>

    <!-- 6.quater Action serveur : Délettrer (annuler le lettrage) -->
    <record id="action_server_delettrer_lignes" model="ir.actions.server">
        <field name="name">Délettrer les écritures sélectionnées</field>
        <field name="model_id" ref="account.model_account_move_line"/>
        <field name="binding_model_id" ref="account.model_account_move_line"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    to_unreconcile = records.filtered(lambda l: l.reconciled or l.matched_debit_ids or l.matched_credit_ids)
    if not to_unreconcile:
        raise UserError("Aucune ligne lettrée dans la sélection.")
    to_unreconcile.remove_move_reconcile()
    action = {
        'type': 'ir.actions.client',
        'tag': 'display_notification',
        'params': {
            'title': 'Délettrage effectué',
            'message': '%d ligne(s) délettrée(s).' % len(to_unreconcile),
            'type': 'warning',
        },
    }
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 3.1.4 — GESTION BANCAIRE
         ══════════════════════════════════════════════════════════════════ -->

    <!-- 3.1.4.a Réactiver la création manuelle (bouton Nouveau) pour les relevés bancaires -->
    <record id="view_bank_statement_tree_create_fix" model="ir.ui.view">
        <field name="name">account.bank.statement.tree.create.fix</field>
        <field name="model">account.bank.statement</field>
        <field name="inherit_id" ref="account.view_bank_statement_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <!-- Enlève la restriction create="false" imposée par Odoo Community -->
                <attribute name="create">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- 3.1.4.b Action pour de vraies Opérations Bancaires Manuelles (Bypass Odoo 17) -->
    <record id="action_compta_operations_bancaires_manuelles" model="ir.actions.act_window">
        <field name="name">Opérations Bancaires &amp; Caisse</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('journal_id.type', 'in', ('bank', 'cash')), ('move_type', '=', 'entry')]</field>
        <field name="context">{'default_move_type': 'entry'}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Enregistrez une nouvelle opération bancaire ou de caisse
          </p>
        </field>
    </record>

    <!-- 3.1.4.c Action pour le Suivi des Comptes (Reporting Trésorerie) -->
    <record id="action_compta_suivi_comptes_bancaires" model="ir.actions.act_window">
        <field name="name">Suivi des Comptes Bancaires</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">tree,pivot</field>
        <field name="domain">[('account_id.account_type', '=', 'asset_cash'), ('parent_state', '=', 'posted')]</field>
        <field name="context">{'search_default_groupby_account_id': 1}</field>
    </record>

    <!-- 3.1.4.d Vue liste enrichie des transactions bancaires à rapprocher -->
    <record id="view_bank_statement_line_transactions_list" model="ir.ui.view">
        <field name="name">account.bank.statement.line.transactions.list</field>
        <field name="model">account.bank.statement.line</field>
        <field name="arch" type="xml">
            <tree string="Transactions Bancaires" create="false" edit="false" delete="false"
                  decoration-warning="not is_reconciled">
                <field name="name" string="Numéro"/>
                <field name="statement_id" string="Nom du relevé" optional="show"/>
                <field name="date"/>
                <field name="journal_id" string="Journal"/>
                <field name="partner_id" string="Partenaire" optional="show"/>
                <field name="payment_ref" string="Référence"/>
                <field name="amount" string="Montant" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="is_reconciled" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- 3.1.4.d Action Transactions Bancaires (lignes de relevé à rapprocher) -->
    <record id="action_compta_transactions_bancaires" model="ir.actions.act_window">
        <field name="name">Transactions Bancaires (à rapprocher)</field>
        <field name="res_model">account.bank.statement.line</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_bank_statement_line_transactions_list"/>
        <field name="domain">[('is_reconciled', '=', False)]</field>
        <field name="context">{'search_default_groupby_journal_id': 1, 'create': False}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Aucune transaction bancaire en attente de rapprochement.
          </p>
          <p>Importez un relevé bancaire via "Importer un Relevé (CSV / OFX / MT940)".</p>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 3.2.4 — MULTI-DEVISES : Historiques
         ══════════════════════════════════════════════════════════════════ -->

    <!-- Historique 1 : Taux de change (res.currency.rate) -->
    <record id="view_compta_currency_rate_tree" model="ir.ui.view">
        <field name="name">compta.res.currency.rate.tree</field>
        <field name="model">res.currency.rate</field>
        <field name="arch" type="xml">
            <tree string="Historique des Taux de Change"
                  default_order="name desc">
                <field name="name" string="Date"/>
                <field name="currency_id" string="Devise"/>
                <field name="rate" string="Taux (1 devise société = X devise)"/>
                <field name="inverse_company_rate"
                       string="Taux inverse (1 devise étrangère = X MAD)"
                       optional="show"/>
                <field name="company_id"
                       groups="base.group_multi_company"
                       optional="show"/>
            </tree>
        </field>
    </record>

    <record id="action_compta_historique_taux_change" model="ir.actions.act_window">
        <field name="name">Historique des Taux de Change</field>
        <field name="res_model">res.currency.rate</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_compta_currency_rate_tree"/>
        <field name="context">{'search_default_group_by_currency_id': 1}</field>
    </record>

    <!-- Historique 2 : Réévaluations des écarts de conversion -->
    <record id="view_compta_reevaluation_history_tree" model="ir.ui.view">
        <field name="name">compta.reevaluation.history.tree</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <tree string="Historique des Réévaluations"
                  default_order="date desc"
                  create="false" delete="false">
                <field name="date" string="Date d'évaluation"/>
                <field name="name" string="N° OD"/>
                <field name="journal_id" string="Journal"/>
                <field name="company_id"
                       groups="base.group_multi_company"
                       optional="show"/>
                <field name="state" string="Statut"
                       decoration-success="state == 'posted'"
                       decoration-warning="state == 'draft'"/>
                <field name="amount_total" string="Montant total écart" sum="Total"/>
            </tree>
        </field>
    </record>

    <record id="action_compta_historique_reevaluation" model="ir.actions.act_window">
        <field name="name">Historique des Réévaluations</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_compta_reevaluation_history_tree"/>
        <field name="domain">[
            ('ref', 'ilike', 'Évaluation Fin de Période'),
            ('move_type', '=', 'entry'),
        ]</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 3.2.4 — MULTI-DEVISES : Réglages
         Ajoute dans Comptabilité › Configuration › Paramètres la case
         « Mise à jour auto des taux » + le fournisseur de taux + le bouton
         de mise à jour manuelle. (Bloc TVA omis : déjà fourni par 3.1.5.)
         ══════════════════════════════════════════════════════════════════ -->
    <record id="res_config_settings_view_form_compta_maroc" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.compta.maroc</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="100"/>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="attributes">
                <attribute name="string">Facturation &amp; comptabilité</attribute>
                <attribute name="data-string">Facturation &amp; comptabilité</attribute>
            </xpath>
            <xpath expr="//block[@id='account_vendor_bills']" position="after">
                <block title="Mode Multi-Devises (Odoo Maroc)" id="compta_maroc_settings_currency">
                    <setting string="Gestion des Taux de Change (Devises)" help="Télécharger les taux de change automatiquement chaque jour (FloatRates).">
                        <field name="auto_currency_update"/>
                        <div class="content-group" invisible="not auto_currency_update">
                            <div class="mt16">
                                <label for="currency_provider" class="o_light_label"/>
                                <field name="currency_provider" class="oe_inline" required="auto_currency_update"/>
                            </div>
                            <div class="mt8">
                                <button name="action_update_currency_rates_config" icon="fa-refresh" type="object" string="Mettre à jour maintenant (Manuel)" class="btn-primary"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
